rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Admins collection - used for custom client-side admin session authentication
    match /admins/{adminId} {
      allow read, write: if true;
    }
    
    // Resellers collection - used for custom reseller login and listing/registration
    match /resellers/{resellerId} {
      allow read, write: if true;
    }
    
    // Tags collection - scanned tags, plate profiles, and owner registration records
    match /tags/{tagId} {
      allow read, write: if true;
    }
    
    // Scan Logs collection - logged when users scan tag QR codes
    match /scan_logs/{logId} {
      allow read, write: if true;
    }
    
    // WhatsApp Clicks collection - contacts generated, evaluated for rate limits
    match /whatsapp_clicks/{clickId} {
      allow read, write: if true;
    }

    // Default safety net deny rule
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
